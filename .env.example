# Anthropic API Key — required for HTML page generation (executor/llm.ts)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI API Key — used by llm-router when model=gpt is requested
OPENAI_API_KEY=sk-xxx

# GitHub Personal Access Token for PR creation (needs repo scope)
GITHUB_TOKEN=ghp_xxx

# API Configuration
API_PORT=3001
API_HOST=localhost

# Frontend Environment Variables
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_TENANT_ID=test-tenant
# GitHub repository to use as the landing page template (owner/repo format)
NEXT_PUBLIC_REPOSITORY_URL=https://github.com/YOUR_USERNAME/vibe-landing-template

# Executor Configuration
EXECUTOR_POLL_INTERVAL=5000
MAX_ITERATIONS=6
MAX_CONTEXT_SIZE=50000
MAX_DIFF_SIZE=5000

# Database and Storage Paths
DATABASE_PATH=./data/vibe.db
PREVIEWS_DIR=/data/previews
PUBLISHED_DIR=/data/published

# Mode A: Project repositories (when implemented)
# REPOS_DIR=./data/repos

# Mode A: Temporary worktrees for isolated job execution (when implemented)
# WORKTREES_DIR=./data/worktrees

# Failed patches directory (for debugging)
PATCHES_DIR=/data/patches

# Docker Preflight Commands (customize per project)
LINT_COMMAND=npm run lint
TYPECHECK_COMMAND=npm run typecheck
TEST_COMMAND=npm test
SMOKE_COMMAND=echo "Smoke test placeholder"
BUILD_COMMAND=npm run build
PREFLIGHT_TIMEOUT=300000

# Git Configuration
GIT_AUTHOR_NAME=VIBE Bot
GIT_AUTHOR_EMAIL=vibe@example.com

# Supabase Integration (required for data storage)
# Project URL from the Supabase dashboard (Settings → API)
# Used as the primary database and for calling Edge Functions
SUPABASE_URL=https://your-project.supabase.co
# Public anon key — used by the API to authenticate Edge Function calls
SUPABASE_ANON_KEY=eyJ...
# Service role key — server-side only, never log or expose to clients
# Used by the API for all data operations (bypasses RLS)
SUPABASE_SERVICE_KEY=eyJ...
# 32+ char random string used to encrypt per-project Supabase service keys at rest
ENCRYPTION_KEY=change-me-to-a-long-random-secret
